<odoo>
    <record id="view_workout_list" model="ir.ui.view">
        <field name="name">fitness.workout.list</field>
        <field name="model">fitness.workout</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="workout_volume"/>
            </list>
        </field>
    </record>

    <record id="view_workout_form" model="ir.ui.view">
        <field name="name">fitness.workout.form</field>
        <field name="model">fitness.workout</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="exercise_ids" nolabel="1">
                        <list editable="bottom" open_form_view="1">
                            <field name="catalog_id" string=" "/>
                        </list>
                    </field>
                </group>
                <group>
                    <field name="workout_volume"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_workouts" model="ir.actions.act_window">
        <field name="name">Workouts</field>
        <field name="res_model">fitness.workout</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

